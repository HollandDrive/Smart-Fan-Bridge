#!/bin/bash
# Smart Fan Bridge — Example startup script
# Copy this to start_bridge.sh and fill in your values.
# Per-fan settings (Tuya keys, IPs, Zigbee addresses, Arjan device IDs) live in fans_config.json.

export MQTT_HOST=localhost
export MQTT_PORT=1883

export HOMEY_URL=http://YOUR_HOMEY_IP:4859
export HOMEY_TOKEN=your-userId:your-sessionId:your-tokenSalt

export CONFIG_FILE=/root/fans_config.json

# Optional tuning (defaults shown)
export POLL_INTERVAL=1.0
export FAN_MONITOR_INTERVAL=2.0
export FAN_OFFLINE_THRESHOLD=3
export SEQUENCE_GRACE_PERIOD=10.0
export TUYA_BOOT_WAIT=3.0
export TUYA_RETRY_INTERVAL=3.0
export TUYA_MAX_RETRIES=8

python3 -u smart_fan_bridge.py
